{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "BluTask",
  "version": "1.0.9",
  "identifier": "com.blutask.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "BluTask",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }

  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Theos21/BluTask/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNCRDlBNkY4MkE2NUU2NDAKUldSQTVtVXErS2JaTzgzYzJVZ0wxVzdhMEZjTERqQ3BvNzRmSzdhY1pFTGR4VnIxWHhjWmkrc04K"
    }
  }
}
